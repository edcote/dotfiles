# ---------------------------------------------------------------------
# General Settings
# ---------------------------------------------------------------------

set -g base-index 1
set -g pane-base-index 1
set -g renumber-windows on

set -g allow-rename off

set -g history-limit 100000

set -g mouse on

# Allow double-clicking to select whole paths
set -g word-separators " @=()[]:\"'"

# ---------------------------------------------------------------------
# Terminal Settings
# ---------------------------------------------------------------------

set -g default-terminal "tmux-256color"
# Enable RGB (true color) and hyperlinks (OSC 8) for Alacritty
set -as terminal-features ",xterm-256color:RGB:hyperlinks,alacritty:RGB:hyperlinks"
set -s set-clipboard on

# ---------------------------------------------------------------------
# Vim Friendliness
# ---------------------------------------------------------------------

# Address vim mode switching delay
set -s escape-time 0

# Enable focus events for auto-read, gitgutter, etc.
set -g focus-events on

set-window-option -g mode-keys vi

# ---------------------------------------------------------------------
# Status Bar
# ---------------------------------------------------------------------

set -g status-left-length 20
set -g status-left "[#S] "
{{- if (contains "google" .chezmoi.homeDir) }}
set -g status-right "#{?@jetski_alert,#[fg=red,bold][#{@jetski_alert}] ,}"
# Clear Jetski alert on window selection
set-hook -g after-select-window 'run-shell "tmux set-option -u @jetski_alert"'
{{- else }}
set -g status-right ""
{{- end }}

# Different colors for different hostnames
{{- if (contains "arthur" .chezmoi.fqdnHostname) }}
set -g status-bg DarkGreen
set -g status-fg color251
{{- else if (contains "wilfrid" .chezmoi.fqdnHostname) }}
set -g status-bg Gold
set -g status-fg Black
{{- else if (contains "nana" .chezmoi.fqdnHostname) }}
set -g status-bg HotPink
set -g status-fg Black
{{- else if (contains "pepe" .chezmoi.fqdnHostname) }}
set -g status-bg DarkBlue
set -g status-fg color251
{{- else if (contains "maureen" .chezmoi.fqdnHostname) }}
set -g status-bg DarkRed
set -g status-fg color251
{{- else if (contains "redondo" .chezmoi.fqdnHostname) }}
set -g status-bg DarkMagenta
set -g status-fg White
{{- else }}
set -g status-bg Green
set -g status-fg White
{{- end }}

# ---------------------------------------------------------------------
# Key Bindings
# ---------------------------------------------------------------------

# Reload config file
bind r source-file ~/.tmux.conf \; display-message "tmux.conf reloaded"

# Option xterm-keys passed modifiers keys (e.g., Ctrl+Arrows) to applications
# running inside tmux
bind x set-option -g xterm-keys \; display "xterm-keys: #{?xterm-keys,ON,OFF}"

# Split panes using | and -
bind | split-window -h -c '#{pane_current_path}'
bind - split-window -v -c '#{pane_current_path}'
unbind '"'
unbind %

# Navigation (no prefix)
bind -n C-S-Left select-pane -L
bind -n C-S-Right select-pane -R
bind -n C-S-Up select-pane -U
bind -n C-S-Down select-pane -D
bind -n M-Left previous-window
bind -n M-Right next-window

# Resize panes using Vi keys (repeatable)
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# ---------------------------------------------------------------------
# Plugins
# ---------------------------------------------------------------------

# Don't forget to clone plugin manager (tpm) manually:
# `git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm`
# Also. don't forget to install plugins using `C-b I`
set -g @plugin 'tmux-plugins/tmux-yank'

run-shell '~/.tmux/plugins/tpm/tpm'
