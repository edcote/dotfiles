[window]
opacity = 1.0
decorations = "Full"
dynamic_title = false

[font]
{{- if (contains "arthur" .chezmoi.fqdnHostname) }}
size = 11.0
{{- else }}
size = 14.0
{{- end }}
normal = { family = "JetBrainsMono Nerd Font", style = "Regular" }

[env]
TERM = "xterm-256color"

[selection]
save_to_clipboard = true

[[hints.enabled]]
regex = '(ipfs:|ipns:|magnet:|mailto:|gemini:|https:|http:|file:|git:|ssh:|ftp:)\S+'
hyperlinks = true
command = "google-chrome"
post_processing = true
mouse = { enabled = true, mods = "Control" }
binding = { key = "U", mods = "Control|Shift" }
