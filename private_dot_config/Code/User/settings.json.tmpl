{{- $google3 := contains "google" .chezmoi.homeDir -}}
{
  // ===================================================================
  // Editor General Settings
  // ===================================================================
  "editor.tabSize": 2,
  "editor.useTabStops": false,
  "editor.renderWhitespace": "trailing",
  "editor.minimap.enabled": false,
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  // ===================================================================
  // Formatting Settings
  // ===================================================================
  {{- if $google3 }}
  "editor.defaultFormatter": "google.lsp",
  "clang-format.executable": "${workspaceRoot}/conda/bin/clang-format",
  "only-verible-verilog-format.executablePath": "${workspaceRoot}/verible-verilog-format",
  {{- end }}

  // ===================================================================
  // Font Settings
  // ===================================================================
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Inconsolata', 'Consolas', 'Droid Sans Mono', monospace",
  "editor.fontSize": 14,
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'Inconsolata', 'Consolas', 'Droid Sans Mono', monospace",
  "terminal.integrated.fontSize": 14,

  // ===================================================================
  // Terminal General Settings
  // ===================================================================
  {{- if $google3 }}
  "terminal.integrated.enableCidermux": true,
  {{- end }}
  "terminal.integrated.allowChords": false,
  "terminal.integrated.commandsToSkipShell": [
    "-workbench.action.quickOpen" // Allow Ctrl-P to reach the shell
  ],

  // ===================================================================
  // Vim Extension Settings
  // ===================================================================
  "vim.autoindent": false,
  "vim.cursorStylePerMode.insert": "line",
  "vim.cursorStylePerMode.normal": "block",
  "vim.cursorStylePerMode.replace": "block-outline",
  "vim.cursorStylePerMode.visual": "block",
  "vim.cursorStylePerMode.visualblock": "block",
  "vim.highlightedyank.enable": true,
  "vim.hlsearch": true,
  "vim.mouseSelectionGoesIntoVisualMode": false,
  "vim.statusBarColorControl": true,
  "vim.useSystemClipboard": true,
  "vim.handleKeys": {
    "<Up>": true,
    "<Down>": true,
    "<Left>": true,
    "<Right>": true,
    "<C-R>": true, // Redo
    "<C-V>": true, // Enter visual block mode
    "<C-W>": true, // Split prefix
    // Page up and down
    "<C-B>": true,
    "<C-F>": true,
    "<C-U>": true,
    "<C-D>": true,
    // Move screen up and down one line
    "<C-Y>": true,
    "<C-E>": true,
    // Move screen up and down one line
    "<C-I>": true,
    "<C-O>": true,
    // Move to {top,middle,last} line of screen
    "<H>": true,
    "<M>": true,
    "<L>": true,
    // Move to last line of file
    "<G>": true
  },

  // ===================================================================
  // Workbench & UI Settings
  // ===================================================================
  {{- if $google3 }}
  "workbench.colorTheme": "Cider Dark",
  {{- else }}
  "workbench.colorTheme": "Visual Studio Dark",
  {{- end }}
  "workbench.editor.enablePreview": false,
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.startupEditor": "none",
  "workbench.view.alwaysShowHeaderActions": true,

  // ===================================================================
  // System & Performance
  // ===================================================================
  "telemetry.telemetryLevel": "off",
  "output.smartScroll.enabled": false,
  "security.workspace.trust.untrustedFiles": "open"
}
